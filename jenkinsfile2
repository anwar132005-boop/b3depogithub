pipeline {
    agent any
    
    stages {
        stage('clear workspace') {
            steps {
                cleanWs()
            }
        }
        
        stage('checkout SCM') {
            steps {
                git branch: 'main', 
                    credentialsId: 'etudiant', 
                    url: 'https://github.com/anwar132005-boop/b3depogithub.git'
            }
        }
        
        stage('fix dpkg') {
            steps {
                sh '''
                    # Réparer l'état de dpkg
                    sudo dpkg --configure -a || true
                    sudo apt --fix-broken install -y || true
                '''
            }
        }
        
        stage('install docker') {
            steps {
                sh '''
                    # Nettoyer et mettre à jour
                    sudo apt clean
                    sudo apt update || { sudo rm -rf /var/lib/apt/lists/* && sudo apt update; }
                    
                    # Installer Docker
                    sudo apt install -y ca-certificates curl gnupg lsb-release
                    
                    # Ajouter la clé GPG Docker
                    sudo mkdir -p /etc/apt/keyrings
                    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg
                    
                    # Ajouter le dépôt Docker
                    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
                    
                    # Installer Docker Engine
                    sudo apt update
                    sudo apt install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin
                    
                    # Configurer les permissions
                    sudo usermod -aG docker jenkins
                    newgrp docker || true
                    
                    # Tester Docker
                    sudo docker run hello-world
                '''
            }
        }
        
        stage('test create container') {
            steps {
                sh '''
                    docker image ls
                    docker pull ubuntu/apache2
                    docker run -d --name container01 --hostname container01 ubuntu/apache2
                    docker ps
                '''
            }
        }
    }
    
    post {
        always {
            sh '''
                # Nettoyer les conteneurs pour éviter les conflits
                docker stop container01 || true
                docker rm container01 || true
            '''
        }
    }
}
